# ============================================================
# PUFA Law — Environment Variables (salin ke .env lalu isi)
# ============================================================

# --- Database (Supabase Postgres) ---
# Ambil dari Supabase > Project > Connect (atau Settings > Database).
# DATABASE_URL = Transaction pooler (port 6543) untuk runtime serverless/Vercel:
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL = Session pooler (port 5432) untuk Prisma CLI (db push/migrate):
DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# --- Situs ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Auth.js / NextAuth ---
# Buat secret: `npx auth secret` atau `openssl rand -base64 32`
AUTH_SECRET=""

# --- Supabase Storage (upload foto) ---
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""        # rahasia — hanya di server
SUPABASE_STORAGE_BUCKET="pufa-media"
